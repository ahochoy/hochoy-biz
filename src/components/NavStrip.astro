---
const moonIcon = "/icons/moon.svg";
const sunIcon = "/icons/sun.svg";
---

<nav class="hero-nav">
  <span class="hero-nav-logo">AH.</span>
  <div class="hero-nav-right">
    <button
      id="theme-toggle"
      class="hero-theme-btn"
      aria-label="Toggle dark mode"
      title="Toggle dark / light mode"
    >
      <span class="theme-icon-light" aria-hidden="true">
        <img src={sunIcon} width="20" height="20" alt="Light mode" />
      </span>
      <span class="theme-icon-dark" aria-hidden="true">
        <img src={moonIcon} width="20" height="20" alt="Dark mode" />
      </span>
    </button>
  </div>
</nav>

<script>
  const btn = document.getElementById('theme-toggle');
  btn?.addEventListener('click', () => {
    const html = document.documentElement;
    const isDark = html.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  });
</script>

<style>
  /* ── Nav ──────────────────────────────────────────────── */
  .hero-nav {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: clamp(1rem, 3vw, 2rem) var(--pad-x);
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.05); 
    backdrop-filter: blur(6px);
  }

  .hero-nav-logo {
    font-family: var(--font-heading);
    font-size: clamp(0.85rem, 5vw, 2rem);
    font-weight: 300;
    letter-spacing: -0.01em;
    color: #ffffff;
    
  }

  .hero-nav-right {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  /* Dark mode toggle button */
  .hero-theme-btn {
    background: none;
    border: 1px solid rgba(255, 255, 255, 0.3);
    color: #ffffff;
    cursor: pointer;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    transition: border-color 0.2s ease, background 0.2s ease;
    padding: 0;
  }

  .hero-theme-btn:hover {
    border-color: rgba(255, 255, 255, 0.8);
    background: rgba(255, 255, 255, 0.1);
  }

  .hero-theme-btn:focus-visible {
    outline: 2px solid #ffffff;
    outline-offset: 2px;
  }

  /* Show moon in light mode, sun in dark mode */
  .theme-icon-dark  { display: none; }
  .theme-icon-light { display: inline; }

  :global(.dark) .theme-icon-light { display: none; }
  :global(.dark) .theme-icon-dark  { display: inline; }

  @media (max-width: 480px) {
    .hero-nav-scroll { display: none; }
  }
</style>
