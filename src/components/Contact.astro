---
import contactData from '../data/contact.json';
---

<div id="contact" class="contact-section">
  <div class="contact-buttons">
    {contactData.map((btn) => (
      <a
        href={btn.href}
        target="_blank"
        rel="noopener noreferrer"
        class="contact-btn"
      >
        <span class="contact-btn-label">{btn.label}</span>
        <span class="contact-btn-arrow" aria-hidden="true">→</span>
      </a>
    ))}
  </div>
</div>

<style>
  /* page-section provides border-top + x-padding from BaseLayout */
  .contact-section {
    /* no extra overrides needed */
  }

  /* ── Button grid: 1px rules between cells ────────────────── */
  .contact-buttons {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--color-rule);
    border: 1px solid var(--color-rule);
    overflow: hidden;
    margin-top: var(--space-lg);
  }

  .contact-btn {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: clamp(1.5rem, 4vw, 2.5rem) clamp(1rem, 2.5vw, 1.75rem);
    background: var(--color-bg);
    min-height: clamp(6rem, 12vw, 9rem);
    gap: var(--space-md);
    transition: background 0.2s ease;
  }

  .contact-btn:hover {
    background: var(--color-text);
  }

  .contact-btn:hover .contact-btn-label,
  .contact-btn:hover .contact-btn-arrow {
    color: var(--color-bg);
  }

  .contact-btn:hover .contact-btn-arrow {
    transform: translateX(4px);
  }

  .contact-btn:focus-visible {
    outline: 2px solid var(--color-text);
    outline-offset: -2px;
  }

  .contact-btn-label {
    font-family: var(--font-heading);
    font-size: clamp(1.25rem, 2.5vw, 2rem);
    font-weight: 300;
    letter-spacing: -0.02em;
    line-height: 1.2;
    color: var(--color-text);
    transition: color 0.2s ease;
  }

  .contact-btn-arrow {
    font-size: clamp(1.25rem, 2vw, 1.5rem);
    color: var(--color-text-muted);
    flex-shrink: 0;
    transition: color 0.2s ease, transform 0.2s ease;
  }

  @media (max-width: 580px) {
    .contact-buttons {
      grid-template-columns: 1fr;
    }
  }
</style>
