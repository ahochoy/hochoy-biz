---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Not Found | Andrew Hochoy" description="This page doesn't exist.">
  <div class="not-found">
    <div class="not-found-number">404</div>
    <h1 class="not-found-heading">Page not found</h1>
    <p class="not-found-body">This page doesn't exist or has moved.</p>
    <a href="/" class="not-found-link">← Back home</a>
  </div>
</BaseLayout>

<style>
  .not-found {
    min-height: 80vh;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: var(--space-md);
    padding: var(--space-xl) var(--pad-x);
    border-top: 1px solid var(--color-rule);
  }

  .not-found-number {
    font-family: var(--font-heading);
    font-size: clamp(6rem, 20vw, 16rem);
    font-weight: 300;
    line-height: 0.9;
    letter-spacing: -0.04em;
    color: var(--color-rule);
    margin-bottom: var(--space-sm);
  }

  .not-found-heading {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 300;
    letter-spacing: -0.03em;
    color: var(--color-text);
    line-height: 1;
  }

  .not-found-body {
    font-family: var(--font-body);
    font-size: clamp(1rem, 1.5vw, 1.125rem);
    color: var(--color-text-muted);
  }

  .not-found-link {
    margin-top: var(--space-lg);
    padding: clamp(0.75rem, 1.5vw, 1rem) clamp(1.5rem, 3vw, 2.5rem);
    border: 1px solid var(--color-rule);
    color: var(--color-text);
    font-family: var(--font-body);
    font-size: clamp(1rem, 1.2vw, 1.1rem);
    font-weight: 500;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .not-found-link:hover {
    background: var(--color-text);
    color: var(--color-bg);
  }

  .not-found-link:focus-visible {
    outline: 2px solid var(--color-text);
    outline-offset: 2px;
  }
</style>
